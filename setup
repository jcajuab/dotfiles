#!/usr/bin/env bash

set -Eeuo pipefail
shopt -s nullglob globstar

trap 'printf "Error on line %s in %s\n" "${LINENO}" "${BASH_SOURCE[0]}" >&2' ERR

readonly CONFIG_DIR="${HOME}/.config"

require() {
    local mode=""
    local -a missing=()

    case "${1:-}" in
        -c | --command)
            mode="command"
            shift
            ;;
        -f | --font)
            mode="font"
            shift
            ;;
        *)
            printf "Invalid flag for require: %s\n" "${1:-}" >&2
            return 1
            ;;
    esac

    for item in "$@"; do
        case "$mode" in
            command)
                if ! command -v "$item" &>/dev/null; then
                    printf "Required command not found: %s\n" "$item" >&2
                    missing+=("$item")
                fi
                ;;
            font)
                if ! fc-list "$item" &>/dev/null; then
                    printf "Required font not found: %s\n" "$item" >&2
                    missing+=("$item")
                fi
                ;;
        esac
    done

    ((${#missing[@]} == 0))
}

symlink() {
    local -a linked=()

    for arg in "$@"; do
        local src dest abs_src
        local replace=true

        if [[ $arg == *:* ]]; then
            IFS=':' read -r src dest <<<"$arg"
        else
            src="$arg"
            dest="${CONFIG_DIR}/$(basename "$src")"
        fi

        if ! abs_src=$(realpath -- "$src" 2>/dev/null); then
            printf "Source not found: %s\n" "$src" >&2
            continue
        fi

        if [[ -e $dest || -L $dest ]]; then
            local answer
            read -rp "Target exists: $dest. Overwrite? [y/N] " answer
            if [[ ! $answer =~ ^[Yy]$ ]]; then
                replace=false
            else
                rm -rf -- "$dest"
            fi
        fi

        if [[ $replace == true ]]; then
            mkdir -p -- "$(dirname "$dest")"
            ln -snf -- "$abs_src" "$dest"
            linked+=("$dest -> $abs_src")
        fi
    done

    if ((${#linked[@]} > 0)); then
        printf "%s\n" "${linked[@]}"
    fi
}

main() {
    require --command bun direnv fish foot nix nvim starship
    require --font CommitMono

    symlink \
        "${HOME}/.dotfiles/direnv" \
        "${HOME}/.dotfiles/fish" \
        "${HOME}/.dotfiles/foot" \
        "${HOME}/.dotfiles/nix" \
        "${HOME}/.dotfiles/starship"
}

if [[ ${BASH_SOURCE[0]} == "${0}" ]]; then
    main "$@"
fi
