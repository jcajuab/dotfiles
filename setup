#!/usr/bin/env bash

set -euo pipefail

require() {
    local list=$1
    local missing=0

    for cmd in $list; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            echo "'$cmd' command not found" >&2
            missing=1
        fi
    done

    return "$missing"
}

symlink() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: $0 <source> [target_directory]"
        return 1
    fi

    local src="$(realpath -- "$1")"

    local target_dir="${2:-$HOME/.config}"
    local target="$target_dir/$(basename -- "$src")"

    mkdir -p -- "$target_dir"

    local create_symlink=true

    if [[ -e $target || -L $target ]]; then
        read -rp "$target exists. Do you want to remove it? (y/N): " answer
        if [[ $answer =~ ^[Yy]$ ]]; then
            rm -rf -- "$target"
            echo "Removed $target"
        else
            echo "Skipping $target"
            create_symlink=false
        fi
    fi

    if $create_symlink; then
        ln -snf -- "$src" "$target"
        echo "Created $target -> $src"
    fi
}

require 'fc-list realpath'

[[ -n $(fc-list 'mononoki') ]] || {
    echo 'Install mononoki (https://madmalik.github.io/mononoki/)'
    exit 1
}

symlink fish
symlink foot
symlink starship
